# ShishaOS — environment variables (ALL OPTIONAL for the MVP).
# The app runs fully without any of these.

# --- Optional AI fallback (OFF by default) ---------------------------------
# AI only *refines* a low-confidence TasteIntent. It never builds recipes or
# master data. Both must be set for AI to ever be called.
AI_FALLBACK_ENABLED=false
# AI_API_KEY=

# --- Optional real OCR provider --------------------------------------------
# OCR_PROVIDER=google
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Optional web search provider ------------------------------------------
# WEB_SEARCH_PROVIDER=brave
# BRAVE_API_KEY=

# --- Supabase Auth + Postgres (login + per-user persistence) ---------------
# When these are set, ShishaOS switches from the in-memory JSON store to
# Supabase Auth (login) + Postgres (per-user inventory/recipes with RLS).
# Leave them unset for local dev / tests (mock user, JSON store).
#
# The URL and the *publishable* (anon) key are safe to expose to the browser,
# so they are exposed via NEXT_PUBLIC_*. Keep the secret service-role key out
# of this file — set it only in your real server env if you need admin tasks.
#
# Before first login, run supabase/migrations/0001_init_user_data.sql in your
# project's SQL editor (or `supabase db push`).
NEXT_PUBLIC_SUPABASE_URL=https://ykynfdrmtskmyvrrrwux.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_f-qJI_mBbJZDUvT1jt6jaQ_LNL5Eebp

# Server-side aliases (also read by the optional Supabase repository layer).
SUPABASE_URL=https://ykynfdrmtskmyvrrrwux.supabase.co
SUPABASE_KEY=sb_publishable_f-qJI_mBbJZDUvT1jt6jaQ_LNL5Eebp

# --- Kemuri (MakeShop) cart automation (admin-only) -------------------------
# Server-only credentials for pushing items into the shop.kemuri.site cart via
# POST /api/kemuri/add. Set these in your Vercel project env (NOT NEXT_PUBLIC_,
# never commit real values). If unset, items go into an anonymous guest cart
# instead of the member account's cart.
# KEMURI_EMAIL=
# KEMURI_PASS=
