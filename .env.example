# Shisha Flavor OS — environment variables (ALL OPTIONAL for the MVP).
# The app runs fully without any of these.

# --- Optional AI fallback (OFF by default) ---------------------------------
# AI only *refines* a low-confidence TasteIntent. It never builds recipes or
# master data. Both must be set for AI to ever be called.
AI_FALLBACK_ENABLED=false
# AI_API_KEY=

# --- Optional real OCR provider --------------------------------------------
# OCR_PROVIDER=google
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Optional web search provider ------------------------------------------
# WEB_SEARCH_PROVIDER=brave
# BRAVE_API_KEY=

# --- Database driver -------------------------------------------------------
# Default (unset) = JSON-file store. Set to "supabase" to use Supabase Postgres.
# DB_DRIVER=supabase

# Supabase connection (server-only; used when DB_DRIVER=supabase).
#   SUPABASE_URL                = your project URL (https://<ref>.supabase.co)
#   SUPABASE_SERVICE_ROLE_KEY   = service-role key (bypasses RLS; NEVER expose
#                                 to the browser — server actions / RSC only)
# SUPABASE_URL=https://ykynfdrmtskmyvrrrwux.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Optional, for a future browser client / Supabase Auth:
# NEXT_PUBLIC_SUPABASE_URL=https://ykynfdrmtskmyvrrrwux.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
